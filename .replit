modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_BASE_URL = "https://eb9653ad-7025-4b1e-8d47-f00dbb6fd728-00-38py2vbb0v4lu.worf.replit.dev"
GOOGLE_REDIRECT_URI = "https://eb9653ad-7025-4b1e-8d47-f00dbb6fd728-00-38py2vbb0v4lu.worf.replit.dev/api/gmail/callback"
